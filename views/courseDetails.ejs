<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/site.css">
</head>

<body>

    <div class="container">

        <% if (course) { %>

            <div class="card details-card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h2 class="card-title mb-1"><%= course.name %></h2>
                            <small class="text-muted">Category: <%= course.category %></small>
                        </div>
                        <span class="badge bg-primary">Training Course</span>
                    </div>

                    <p class="mt-3 text-muted">
                        <% if (course.description) { %>
                            <%= course.description %>
                        <% } else { %>
                            A professionally designed short course to develop practical skills and knowledge.
                        <% } %>
                    </p>

                    <div class="row g-3 mt-4">
                        <div class="col-md-4">
                            <div class="detail-item">
                                <div class="detail-label">Course Fee</div>
                                <div class="detail-value">R<%= Number(course.fee).toFixed(2) %></div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="detail-item highlight">
                                <div class="detail-label">Discounted Fee (10% Off)</div>
                                <div class="detail-value">R<%= discountedFee %></div>
                            </div>
                        </div>
                        <div class="col-md-4 text-end">
                            <a href="/courses/enrol/<%= course.id %>" class="btn btn-success">Enrol Now</a>
                        </div>
                    </div>

                    <div class="mt-4">
                        <a href="/courses" class="btn btn-outline-primary">Back to Courses</a>
                    </div>
                </div>
            </div>

        <% } else { %>

            <div class="alert alert-warning mt-5" role="alert">
                <h4 class="alert-heading">Course Not Found</h4>
                <p>The course you requested does not exist or may have been removed.</p>
                <hr>
                <a href="/courses" class="btn btn-primary">Return to Courses</a>
            </div>

        <% } %>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>