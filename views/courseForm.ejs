<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/site.css">
</head>

<body>

    <div class="course-form-page">

        <div class="course-form-card">

            <div class="form-header">
                <h1>Add New Course</h1>
                <p>Create a new training programme for learners.</p>
            </div>

            <form action="/courses/create" method="POST" class="modern-course-form">

                <div class="form-group">
                    <label for="name">Course Name</label>

                    <input
                        type="text"
                        id="name"
                        name="name"
                        placeholder="Enter course name"
                        value="<%= oldInput.name || '' %>"
                        class="<%= errors.includes('Course name is required.') ? 'input-error' : '' %>">
                </div>

                <div class="form-group">
                    <label for="fee">Course Fee (R)</label>

                    <input
                        type="number"
                        id="fee"
                        name="fee"
                        placeholder="Enter course fee"
                        value="<%= oldInput.fee || '' %>"
                        class="<%= errors.includes('Course fee must be a positive number.') ? 'input-error' : '' %>">
                </div>

                <div class="form-group">
                    <label for="category">Category</label>

                    <input
                        type="text"
                        id="category"
                        name="category"
                        placeholder="Example: IT, Business, Finance"
                        value="<%= oldInput.category || '' %>"
                        class="<%= errors.includes('Course category is required.') ? 'input-error' : '' %>">
                </div>

                <button type="submit" class="submit-course-btn">
                    Create Course
                </button>

            </form>

            <% if (errors.length > 0) { %>

                <div class="validation-card">

                    <h3>Please fix the following:</h3>

                    <ul>
                        <% errors.forEach(error => { %>
                            <li><%= error %></li>
                        <% }) %>
                    </ul>

                </div>

            <% } %>

        </div>

    </div>

</body>

</html>