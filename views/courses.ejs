<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title><%= title %></title>

    <link
        href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
        rel="stylesheet">

    <link rel="stylesheet" href="/css/site.css">
</head>

<body>

    <div class="container py-5">

        <!-- Page Header -->
        <div class="page-header text-center mb-5">
            <span class="badge bg-primary-subtle text-primary mb-3">
                Community Skills Training Centre
            </span>

            <h1 class="display-5 fw-bold">
                Available Training Courses
            </h1>

            <p class="lead text-muted">
                Explore professional training programmes designed to enhance
                your practical skills.
            </p>
        </div>

        <!-- Success Message -->
        <% if (success_msg) { %>
            <div class="alert alert-success shadow-sm border-0 mb-4">
                <strong>Success!</strong>
                <%= success_msg %>
            </div>
        <% } %>

        <!-- Course Cards -->
        <div class="row g-4">

            <% courses.forEach(function(course) { %>

                <div class="col-lg-4 col-md-6">

                    <div class="course-card">

                        <div class="course-card-header">
                            <span class="course-badge">
                                Professional Course
                            </span>

                            <h4>
                                <%= course.name %>
                            </h4>
                        </div>

                        <div class="course-card-body">

                            <div class="course-price">
                                R<%= course.fee %>
                            </div>

                            <p class="course-description">
                                Structured training and guided learning.
                            </p>

                            <a href="/courses/<%= course.id %>"
                                class="course-btn">
                                View Course Details
                            </a>

                        </div>

                    </div>

                </div>

            <% }); %>

        </div>

        <!-- Call To Action -->
        <div class="cta-section text-center mt-5">

            <h3>
                Ready to add a new course?
            </h3>

            <p class="text-muted mb-4">
                Expand the training catalogue by creating additional learning opportunities.
            </p>

            <a href="/courses/create" class="btn-create-course">
                + Add New Course
            </a>

        </div>

    </div>
    <script 
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" 
    integrity="sha384-ENjdO4Dr2bkBIFxQpeoYz1zWv3yU6k9GqQ8dZr+5smXKp4YfRvH+8abtTE1Pi6jizo"
    crossorigin="anonymous">
</script>

</body>

</html>